# ============================================================
# FilX.io Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development                        # development | production
APP_SECRET_KEY=change-me-to-random-64-chars
APP_BASE_URL=http://localhost:8000         # https://api.filx.io in prod
FRONTEND_URL=http://localhost:3000         # https://filx.io in prod

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://filx:filxpass@localhost:5432/filxio
DATABASE_URL_SYNC=postgresql://filx:filxpass@localhost:5432/filxio

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Cloudflare R2 (file storage) ────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=filx-jobs
R2_ENDPOINT_URL=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.filx.io       # custom domain on R2 bucket
FILE_TTL_SECONDS=3600                      # 1 hour file expiry

# ── x402 / Base Chain ────────────────────────────────────────
X402_TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_ADDRESS
X402_RPC_URL=https://mainnet.base.org
X402_CHAIN_ID=8453
X402_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
X402_PAYMENT_EXPIRY_SECONDS=300            # 5 minutes to complete payment
X402_MIN_CONFIRMATIONS=1

# ── Pricing (in USDC micro-units, 6 decimals) ────────────────
# 1000 = $0.001, 5000 = $0.005, etc.
PRICE_PDF_PER_PAGE=2000                    # $0.002/page
PRICE_OCR_PER_IMAGE=3000                   # $0.003/image
PRICE_IMAGE_CONVERT=1000                   # $0.001/image
PRICE_IMAGE_BG_REMOVE=5000                 # $0.005/image
PRICE_TABLE_EXTRACT_PER_PAGE=3000          # $0.003/page
PRICE_PDF_COMPRESS=2000                    # $0.002/file
PRICE_PDF_MERGE=2000                       # $0.002/merge
PRICE_PDF_SPLIT=2000                       # $0.002/file
PRICE_PDF_ROTATE=1000                      # $0.001/file
PRICE_PDF_UNLOCK=3000                      # $0.003/file

# ── File Limits ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_BATCH_SIZE_MB=200
MAX_BATCH_FILES=10
MAX_PDF_PAGES=500

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# ── Webhook (optional) ───────────────────────────────────────
WEBHOOK_SECRET=your-webhook-signing-secret

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://filx.io

# ============================================================
# FRONTEND (.env.local)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000          # https://api.filx.io
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_ADDRESS
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-wc-project-id
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000          # https://filx.io
